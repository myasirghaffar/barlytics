# Copy this file to keystore.properties and fill in your release keystore details.
# Generate a keystore with:
#   cd android/app && keytool -genkeypair -v -storetype PKCS12 -keystore release.keystore \
#     -alias barbrain-release -keyalg RSA -keysize 2048 -validity 10000
# Then set the path relative to android/app/ (e.g. release.keystore if stored in android/app/).
MYAPP_RELEASE_STORE_FILE=release.keystore
MYAPP_RELEASE_STORE_PASSWORD=your-store-password
MYAPP_RELEASE_KEY_ALIAS=barbrain-release
MYAPP_RELEASE_KEY_PASSWORD=your-key-password
